<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>truncate</title>
</head>
<body>
<script>
function truncate(str, maxlength) {
    if (str.length > maxlength) {
        return str.slice(0, maxlength - 1) + "…";
    }
    return str;
}
console.log(truncate("Що я хотів би розповісти на цю тему:", 20));
console.log(truncate("Всім привіт!", 20));
</script>
</body>
</html>
